rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function hasMapping(uid) {
      return exists(/databases/$(database)/documents/uid_mappings/$(uid));
    }
    function getOriginalUserId(uid) {
      return get(/databases/$(database)/documents/uid_mappings/$(uid)).data.originalUserId;
    }
    function isOwner(userId) {
      return request.auth != null && (
        request.auth.uid == userId ||
        (hasMapping(request.auth.uid) && getOriginalUserId(request.auth.uid) == userId)
      );
    }
    match /uid_mappings/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if isOwner(userId);
    }
    match /expenses/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if request.auth != null;
    }
    match /groups/{groupId} {
      allow read, update: if request.auth != null && (
        request.auth.uid in resource.data.memberIds ||
        (hasMapping(request.auth.uid) && getOriginalUserId(request.auth.uid) in resource.data.memberIds)
      );
      allow create: if request.auth != null;
    }
    match /notes/{noteId} {
      allow read, write: if request.auth != null;
    }
    match /group_read_status/{docId} {
      allow read, write: if request.auth != null;
    }
    match /debug_logs/{logId} {
      allow read, write: if request.auth != null;
    }
    match /uid_mappings/{uid} {
      allow read, write: if request.auth != null;
    }
  }
}